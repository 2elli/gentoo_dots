##### modules #####
# builtin modules
zmodule input        # sane input keybinds
zmodule utility      # aliases and color for ls, grep, less
# other modules
zmodule mfaerevaag/wd -s wd.plugin.zsh --fpath . # warp dir
zmodule jeffreytse/zsh-vi-mode                   # better vi mode

##### prompt #####
zmodule romkatv/powerlevel10k

##### completion #####
zmodule nix-community/nix-zsh-completions --fpath .
zmodule zsh-users/zsh-completions --fpath src  # generic completion sources
zmodule completion

##### last (modules that must be loaded last) #####
zmodule zsh-users/zsh-syntax-highlighting
zmodule zsh-users/zsh-autosuggestions
